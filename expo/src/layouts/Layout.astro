---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Fluent App is a native macOS menu bar app for AI-powered text shortcuts. Translate, rewrite, summarize, and improve selected text from any app.",
  image = "/og-image.png"
} = Astro.props;

const siteName = "Fluent App";
const siteUrl = "https://fluentapp.vercel.app";
const twitterHandle = "@alfonsobries";
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (s === 'dark' || (!s && d)) document.documentElement.classList.add('dark');
      })();
    </script>

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="macOS ai app, menu bar ai shortcuts, translate text mac, rewrite selected text, summarize text mac, grammar shortcut app, OpenAI mac app, Claude mac app, Gemini mac app, Grok mac app" />
    <meta name="author" content="Alfonso Bribiesca" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />
    <meta name="twitter:creator" content={twitterHandle} />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Fluent App",
        "operatingSystem": "macOS",
        "applicationCategory": "UtilitiesApplication",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": "Fluent App is a native macOS menu bar app for AI-powered text shortcuts",
        "downloadUrl": "https://github.com/alfonsobries/fluent-app/releases/latest",
        "softwareVersion": "1.2.0",
        "author": {
          "@type": "Person",
          "name": "Alfonso Bribiesca",
          "url": "https://github.com/alfonsobries"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5",
          "ratingCount": "1"
        }
      }
    </script>

    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen bg-white text-gray-900 dark:bg-black dark:text-gray-100">
    <slot />
  </body>
</html>
