---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TranslateTool">
  <main>
    <header>
      <nav>
        <span class="logo">TranslateTool</span>
        <a href="https://github.com/alfonsobries/translate-tool">GitHub</a>
      </nav>
    </header>

    <section class="hero">
      <h1>Process text with AI,<br/>from anywhere on your Mac.</h1>
      <p class="lead">
        Select text. Press a shortcut. Get results instantly.<br/>
        Translate, improve writing, fix grammar — all without switching apps.
      </p>
      <div class="actions">
        <a href="https://github.com/alfonsobries/translate-tool/releases/latest" class="btn-primary">Download for macOS</a>
        <span class="note">Requires macOS 13.0+</span>
      </div>
    </section>

    <section class="how">
      <div class="step">
        <span class="num">1</span>
        <div>
          <h3>Select any text</h3>
          <p>In any application — browser, editor, email, notes.</p>
        </div>
      </div>
      <div class="step">
        <span class="num">2</span>
        <div>
          <h3>Press your shortcut</h3>
          <p>Default is <kbd>Cmd</kbd> <kbd>Shift</kbd> <kbd>O</kbd> for translate.</p>
        </div>
      </div>
      <div class="step">
        <span class="num">3</span>
        <div>
          <h3>Done</h3>
          <p>The processed text replaces your selection automatically.</p>
        </div>
      </div>
    </section>

    <section class="features">
      <h2>Features</h2>
      <div class="grid">
        <div class="item">
          <h3>Multiple AI Providers</h3>
          <p>OpenAI, Claude, Gemini, or Grok. Choose your preferred model and switch anytime.</p>
        </div>
        <div class="item">
          <h3>Custom Shortcuts</h3>
          <p>Create unlimited shortcuts with custom AI instructions. Record keys visually.</p>
        </div>
        <div class="item">
          <h3>Works System-wide</h3>
          <p>Global keyboard shortcuts work in any application. No context switching.</p>
        </div>
        <div class="item">
          <h3>Privacy First</h3>
          <p>API keys stored locally. Text sent directly to your chosen provider. No tracking.</p>
        </div>
        <div class="item">
          <h3>Native Performance</h3>
          <p>Built with Swift. Lives in your menu bar. Minimal resource usage.</p>
        </div>
        <div class="item">
          <h3>Open Source</h3>
          <p>MIT licensed. Review the code, contribute, or fork it.</p>
        </div>
      </div>
    </section>

    <section class="shortcuts">
      <h2>Default Shortcuts</h2>
      <table>
        <tr>
          <td><kbd>Cmd</kbd> <kbd>Shift</kbd> <kbd>O</kbd></td>
          <td>Translate</td>
          <td>Detect language and translate</td>
        </tr>
        <tr>
          <td><kbd>Cmd</kbd> <kbd>Shift</kbd> <kbd>I</kbd></td>
          <td>Improve</td>
          <td>Better grammar, clarity, style</td>
        </tr>
        <tr class="muted">
          <td><kbd>Cmd</kbd> <kbd>Shift</kbd> <kbd>G</kbd></td>
          <td>Grammar</td>
          <td>Fix spelling and grammar only</td>
        </tr>
      </table>
      <p class="note">All shortcuts are customizable. Create your own with any prompt.</p>
    </section>

    <section class="providers">
      <h2>Supported Providers</h2>
      <div class="provider-list">
        <div class="provider">
          <strong>OpenAI</strong>
          <span>GPT-4o-mini</span>
        </div>
        <div class="provider">
          <strong>Anthropic</strong>
          <span>Claude 3 Haiku</span>
        </div>
        <div class="provider">
          <strong>Google</strong>
          <span>Gemini 1.5 Flash</span>
        </div>
        <div class="provider">
          <strong>xAI</strong>
          <span>Grok</span>
        </div>
      </div>
    </section>

    <section class="setup">
      <h2>Setup</h2>
      <ol>
        <li>Download and drag to Applications</li>
        <li>Open and grant Accessibility permissions</li>
        <li>Add your API key from your preferred provider</li>
        <li>Start using — select text and press your shortcut</li>
      </ol>
    </section>

    <footer>
      <p>
        Built by <a href="https://github.com/alfonsobries">Alfonso Bribiesca</a>
      </p>
      <p>
        <a href="https://github.com/alfonsobries/translate-tool">Source</a> ·
        <a href="https://github.com/alfonsobries/translate-tool/issues">Issues</a> ·
        <a href="https://github.com/alfonsobries/translate-tool/blob/main/LICENSE">MIT License</a>
      </p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  header {
    padding: 24px 0;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 80px;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  nav a {
    font-size: 0.875rem;
    color: #666;
  }

  /* Hero */
  .hero {
    margin-bottom: 100px;
  }

  h1 {
    font-size: 2.75rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
  }

  .lead {
    font-size: 1.125rem;
    color: #666;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 12px 24px;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn-primary:hover {
    background: #333;
    text-decoration: none;
  }

  .note {
    font-size: 0.8125rem;
    color: #999;
  }

  /* How it works */
  .how {
    margin-bottom: 100px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .num {
    width: 32px;
    height: 32px;
    border: 1.5px solid #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 500;
    flex-shrink: 0;
  }

  .step h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .step p {
    font-size: 0.9375rem;
    color: #666;
  }

  /* Sections */
  section {
    margin-bottom: 100px;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }

  /* Features */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 48px;
  }

  .item h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .item p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
  }

  /* Shortcuts */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  tr {
    border-bottom: 1px solid #e5e5e5;
  }

  td {
    padding: 16px 0;
    vertical-align: top;
  }

  td:first-child {
    width: 200px;
    white-space: nowrap;
  }

  td:nth-child(2) {
    font-weight: 500;
    width: 100px;
  }

  td:last-child {
    color: #666;
  }

  tr.muted {
    color: #999;
  }

  tr.muted td:nth-child(2) {
    font-weight: 400;
  }

  .shortcuts .note {
    margin-top: 24px;
    display: block;
  }

  /* Providers */
  .provider-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .provider {
    text-align: center;
  }

  .provider strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .provider span {
    font-size: 0.8125rem;
    color: #666;
  }

  /* Setup */
  ol {
    list-style: none;
    counter-reset: setup;
  }

  ol li {
    counter-increment: setup;
    padding: 16px 0;
    border-bottom: 1px solid #e5e5e5;
    font-size: 0.9375rem;
  }

  ol li::before {
    content: counter(setup) ".";
    margin-right: 12px;
    color: #999;
  }

  /* Footer */
  footer {
    padding: 48px 0;
    border-top: 1px solid #e5e5e5;
    text-align: center;
    margin-top: 100px;
  }

  footer p {
    font-size: 0.8125rem;
    color: #666;
    margin-bottom: 8px;
  }

  footer a {
    color: #666;
  }

  /* Mobile */
  @media (max-width: 640px) {
    header {
      margin-bottom: 48px;
    }

    h1 {
      font-size: 2rem;
    }

    .lead {
      font-size: 1rem;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .provider-list {
      grid-template-columns: repeat(2, 1fr);
    }

    table {
      font-size: 0.875rem;
    }

    td:first-child {
      width: auto;
    }

    td:nth-child(2) {
      display: none;
    }
  }
</style>
