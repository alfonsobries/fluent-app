---
import Layout from '../layouts/Layout.astro';

const title = 'Fluent App — AI text shortcuts for macOS';
const description =
  'Translate, rewrite, and improve selected text from any macOS app with a keyboard shortcut. Open source, uses your own API keys.';
const repoUrl = 'https://github.com/alfonsobries/fluent-app';
const releasesUrl = `${repoUrl}/releases/latest`;
const demoVideoUrl = '/fluent-demo.mp4';
const demoPosterUrl = '/fluent-demo-poster.jpg';

const features = [
  {
    title: 'Works in any app',
    body: 'Select text in Mail, Slack, Notes, Figma, Safari, or your editor. The result replaces the selection in place.'
  },
  {
    title: 'Translate instantly',
    body: 'Detect the language and translate without leaving the app you are working in.'
  },
  {
    title: 'Improve your writing',
    body: 'Fix grammar, adjust tone, or rewrite for clarity with a single shortcut.'
  },
  {
    title: 'Custom shortcuts',
    body: 'Create your own actions — summaries, rewrites, language changes, or any repeated text task.'
  }
];

const steps = [
  { index: '1', title: 'Select text', body: 'Highlight text in any app.' },
  { index: '2', title: 'Press a shortcut', body: 'Use a built-in action or one you created.' },
  { index: '3', title: 'Done', body: 'The result replaces the selection automatically.' }
];

const shortcuts = [
  { keys: ['⌘', '⇧', 'O'], title: 'Translate', body: 'Detect language and translate the selection.' },
  { keys: ['⌘', '⇧', 'I'], title: 'Improve Writing', body: 'Rewrite for clarity, grammar, and tone.' },
  { keys: ['⌘', '⇧', 'S'], title: 'Summarize', body: 'Condense selected text into a short summary.' }
];
---

<Layout title={title} description={description}>
  <main class="mx-auto max-w-3xl px-6 pb-32 pt-16 sm:pt-24">

    <!-- Nav -->
    <header class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 no-underline">
        <img src="/favicon.svg" alt="" class="h-7 w-7 rounded-lg" />
        <span class="text-sm font-semibold text-gray-900 dark:text-white">Fluent App</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden items-center gap-6 text-sm text-gray-500 dark:text-gray-400 sm:flex" aria-label="Primary">
        <a href="#features" class="transition hover:text-gray-900 dark:hover:text-white">Features</a>
        <a href="#how-it-works" class="transition hover:text-gray-900 dark:hover:text-white">How it works</a>
        <a href={repoUrl} class="transition hover:text-gray-900 dark:hover:text-white" target="_blank" rel="noreferrer">GitHub</a>
        <button
          type="button"
          data-theme-toggle
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-gray-200 text-gray-500 transition hover:border-gray-300 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-white"
          aria-label="Toggle theme"
        >
          <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-3 sm:hidden">
        <button
          type="button"
          data-theme-toggle
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-gray-200 text-gray-500 transition hover:border-gray-300 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-white"
          aria-label="Toggle theme"
        >
          <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
        <button
          type="button"
          data-mobile-menu-toggle
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-gray-200 text-gray-500 transition hover:border-gray-300 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-white"
          aria-label="Open menu"
        >
          <!-- Hamburger icon -->
          <svg data-menu-icon-open class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <!-- Close icon -->
          <svg data-menu-icon-close class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile nav menu -->
    <nav data-mobile-menu class="hidden flex-col gap-4 border-b border-gray-200 pb-6 pt-4 text-sm text-gray-500 dark:border-gray-700 dark:text-gray-400 sm:!hidden" aria-label="Mobile">
      <a href="#features" class="transition hover:text-gray-900 dark:hover:text-white">Features</a>
      <a href="#how-it-works" class="transition hover:text-gray-900 dark:hover:text-white">How it works</a>
      <a href={repoUrl} class="transition hover:text-gray-900 dark:hover:text-white" target="_blank" rel="noreferrer">GitHub</a>
    </nav>

    <!-- Hero -->
    <section class="mt-24 sm:mt-32">
      <h1 class="text-4xl font-semibold leading-[1.1] tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        AI text shortcuts<br />for macOS.
      </h1>
      <p class="mt-5 max-w-xl text-base leading-7 text-gray-500 dark:text-gray-400 sm:text-lg sm:leading-8">
        Select text in any app, press a shortcut, get a translation, rewrite, or summary back in place. No copy-pasting, no switching windows.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          class="inline-flex h-10 items-center rounded-md bg-gray-900 px-4 text-sm font-medium text-white transition hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200"
          id="download-dmg"
          href={releasesUrl}
          data-release-api="https://api.github.com/repos/alfonsobries/fluent-app/releases/latest"
          data-release-fallback={releasesUrl}
        >
          Download for macOS
        </a>
        <a
          class="inline-flex h-10 items-center rounded-md border border-gray-200 px-4 text-sm font-medium text-gray-600 transition hover:border-gray-400 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-500 dark:hover:text-white"
          href={repoUrl}
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
      </div>

      <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-400 dark:text-gray-500">
        <span>Open source</span>
        <span>·</span>
        <span>Your own API keys</span>
        <span>·</span>
        <span>macOS 13+</span>
      </div>
    </section>

    <!-- Demo -->
    <section class="mt-20">
      <button
        type="button"
        data-demo-open
        class="group relative block w-full overflow-hidden rounded-xl border border-gray-200 shadow-lg text-left outline-none dark:border-white/15 dark:shadow-none"
        aria-label="Play demo video"
      >
        <img src={demoPosterUrl} alt="Fluent App demo" class="block w-full" />
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="flex h-14 w-14 items-center justify-center rounded-full bg-black/30 text-white backdrop-blur-sm transition group-hover:bg-black/50">
            <svg viewBox="0 0 24 24" class="ml-0.5 h-6 w-6 fill-current" aria-hidden="true">
              <path d="M8 6.5v11l9-5.5-9-5.5Z"></path>
            </svg>
          </span>
        </div>
      </button>
    </section>

    <!-- Features -->
    <section id="features" class="mt-28">
      <p class="text-xs font-medium uppercase tracking-widest text-blue-600 dark:text-blue-400">Features</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Everything happens where you already work.</h2>

      <div class="mt-10 grid gap-8 sm:grid-cols-2">
        {features.map((f) => (
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{f.title}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-500 dark:text-gray-400">{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="mt-28">
      <p class="text-xs font-medium uppercase tracking-widest text-blue-600 dark:text-blue-400">How it works</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Three steps. No context switching.</h2>

      <div class="mt-10 grid gap-px overflow-hidden rounded-lg border border-gray-200 dark:border-white/15 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="bg-gray-50 px-5 py-5 dark:bg-white/[0.03]">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500">{step.index}</p>
            <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-white">{step.title}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-500 dark:text-gray-400">{step.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Shortcuts -->
    <section class="mt-28">
      <p class="text-xs font-medium uppercase tracking-widest text-blue-600 dark:text-blue-400">Default shortcuts</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Ready to use out of the box.</h2>

      <div class="mt-10 divide-y divide-gray-100 dark:divide-white/10">
        {shortcuts.map((s) => (
          <div class="flex flex-col gap-3 py-4 sm:flex-row sm:items-center sm:gap-6">
            <div class="flex shrink-0 items-center gap-1.5">
              {s.keys.map((key) => (
                <kbd class="inline-flex h-7 min-w-[28px] items-center justify-center rounded border border-gray-200 bg-gray-50 px-1.5 font-mono text-xs text-gray-600 dark:border-white/15 dark:bg-white/[0.06] dark:text-gray-300">
                  {key}
                </kbd>
              ))}
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900 dark:text-white">{s.title}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Open source -->
    <section class="mt-28">
      <p class="text-xs font-medium uppercase tracking-widest text-blue-600 dark:text-blue-400">Open source</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Fully open. MIT licensed.</h2>
      <p class="mt-4 text-sm leading-6 text-gray-500 dark:text-gray-400">
        The complete source code, build scripts, and release pipeline are public on GitHub.
        Inspect it, fork it, or ship your own version.
      </p>
      <div class="mt-5 flex flex-wrap gap-4 text-sm">
        <a class="text-gray-900 underline underline-offset-4 decoration-gray-300 transition hover:decoration-gray-500 dark:text-white dark:decoration-gray-600 dark:hover:decoration-gray-400" href={repoUrl} target="_blank" rel="noreferrer">Repository</a>
        <a class="text-gray-900 underline underline-offset-4 decoration-gray-300 transition hover:decoration-gray-500 dark:text-white dark:decoration-gray-600 dark:hover:decoration-gray-400" href={`${repoUrl}/actions`} target="_blank" rel="noreferrer">CI / Releases</a>
        <a class="text-gray-900 underline underline-offset-4 decoration-gray-300 transition hover:decoration-gray-500 dark:text-white dark:decoration-gray-600 dark:hover:decoration-gray-400" href={`${repoUrl}/blob/main/LICENSE`} target="_blank" rel="noreferrer">MIT License</a>
      </div>
    </section>

    <!-- Download CTA -->
    <section class="mt-28 rounded-lg border border-gray-200 bg-gray-50 px-6 py-8 dark:border-white/15 dark:bg-white/[0.03] sm:px-8">
      <h2 class="text-2xl font-semibold tracking-tight text-gray-900 dark:text-white">Get Fluent App</h2>
      <p class="mt-2 text-sm leading-6 text-gray-500 dark:text-gray-400">
        Download the latest build from GitHub Releases. Free and open source.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          class="inline-flex h-10 items-center rounded-md bg-gray-900 px-4 text-sm font-medium text-white transition hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200"
          id="download-release-dmg"
          href={releasesUrl}
          data-release-api="https://api.github.com/repos/alfonsobries/fluent-app/releases/latest"
          data-release-fallback={releasesUrl}
        >
          Download DMG
        </a>
        <a
          class="inline-flex h-10 items-center rounded-md border border-gray-200 px-4 text-sm font-medium text-gray-600 transition hover:border-gray-400 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-500 dark:hover:text-white"
          href={`${repoUrl}/releases`}
          target="_blank"
          rel="noreferrer"
        >
          All Releases
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-28 flex flex-col gap-4 border-t border-gray-100 pt-8 text-sm text-gray-500 dark:border-white/10 dark:text-gray-400 sm:flex-row sm:items-center sm:justify-between">
      <p>Fluent App — open-source AI text shortcuts for macOS.</p>
      <nav class="flex gap-4" aria-label="Footer">
        <a class="transition hover:text-gray-900 dark:hover:text-white" href={repoUrl}>GitHub</a>
        <a class="transition hover:text-gray-900 dark:hover:text-white" href={`${repoUrl}/releases`}>Releases</a>
        <a class="transition hover:text-gray-900 dark:hover:text-white" href={`${repoUrl}/issues`}>Issues</a>
      </nav>
    </footer>
  </main>

  <!-- Video dialog -->
  <dialog
    data-demo-dialog
    class="m-auto w-[min(960px,calc(100vw-32px))] border-0 bg-transparent p-0 shadow-none backdrop:bg-black/70 backdrop:backdrop-blur-sm"
  >
    <div class="relative">
      <button
        type="button"
        data-demo-close
        class="absolute -right-1 -top-10 z-10 inline-flex h-8 w-8 items-center justify-center rounded-full text-white/60 transition hover:text-white"
        aria-label="Close demo"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"></path>
        </svg>
      </button>
      <div class="overflow-hidden rounded-lg border border-gray-200 bg-black dark:border-white/10">
        <video
          data-demo-video
          class="block max-h-[82vh] w-full"
          src={demoVideoUrl}
          poster={demoPosterUrl}
          controls
          playsinline
          preload="metadata"
        ></video>
      </div>
    </div>
  </dialog>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      // Theme toggle (multiple buttons)
      document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      });

      // Mobile menu toggle
      var mobileMenuToggle = document.querySelector('[data-mobile-menu-toggle]');
      var mobileMenu = document.querySelector('[data-mobile-menu]');
      var menuIconOpen = document.querySelector('[data-menu-icon-open]');
      var menuIconClose = document.querySelector('[data-menu-icon-close]');

      if (mobileMenuToggle && mobileMenu) {
        mobileMenuToggle.addEventListener('click', function () {
          var isOpen = mobileMenu.classList.toggle('hidden');
          if (!isOpen) {
            mobileMenu.classList.add('flex');
          } else {
            mobileMenu.classList.remove('flex');
          }
          menuIconOpen.classList.toggle('hidden');
          menuIconClose.classList.toggle('hidden');
        });

        mobileMenu.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            mobileMenu.classList.add('hidden');
            mobileMenu.classList.remove('flex');
            menuIconOpen.classList.remove('hidden');
            menuIconClose.classList.add('hidden');
          });
        });
      }

      // Download buttons
      var buttons = Array.from(document.querySelectorAll('[data-release-api]'));
      if (buttons.length) {
        fetch(buttons[0].dataset.releaseApi, { headers: { Accept: 'application/vnd.github+json' } })
          .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
          .then(function (release) {
            var dmg = (release.assets || []).find(function (a) { return a.name && a.name.endsWith('.dmg'); });
            if (dmg && dmg.browser_download_url) {
              buttons.forEach(function (b) { b.href = dmg.browser_download_url; });
            }
          })
          .catch(function () {});
      }

      // Demo video dialog
      var dialog = document.querySelector('[data-demo-dialog]');
      var video = document.querySelector('[data-demo-video]');

      function closeDemo() {
        if (!dialog || !dialog.open) return;
        dialog.close();
        if (video instanceof HTMLVideoElement) { video.pause(); video.currentTime = 0; }
      }

      document.querySelector('[data-demo-open]').addEventListener('click', function () {
        dialog.showModal();
        if (video instanceof HTMLVideoElement) { video.currentTime = 0; video.play().catch(function () {}); }
      });

      document.querySelector('[data-demo-close]').addEventListener('click', closeDemo);
      dialog.addEventListener('click', function (e) { if (e.target === dialog) closeDemo(); });
    });
  </script>
</Layout>
