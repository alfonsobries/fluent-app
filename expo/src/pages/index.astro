---
import Layout from '../layouts/Layout.astro';

const title = 'Fluent App for macOS';
const description =
  'Fluent App is a native macOS menu bar app for AI-powered text shortcuts. Translate, rewrite, summarize, and improve selected text from any app with a keyboard shortcut.';
const repoUrl = 'https://github.com/alfonsobries/fluent-app';
const releasesUrl = `${repoUrl}/releases/latest`;

const featureCards = [
  {
    title: 'Translate in place',
    body: 'Select text in Mail, Slack, Notes, Safari, VS Code, or any editable app. Fluent App replaces the selection directly.'
  },
  {
    title: 'Custom prompts per shortcut',
    body: 'Create dedicated actions for rewriting, summarizing, translating, fixing grammar, or any custom text workflow.'
  },
  {
    title: 'Bring your own model',
    body: 'Works with OpenAI, Anthropic, Gemini, and Grok so you can keep using the provider you already prefer.'
  },
  {
    title: 'Native and lightweight',
    body: 'Built with Swift and AppKit for a real macOS feel. No Electron shell, no tab switching, no analytics pipeline.'
  }
];

const steps = [
  {
    index: '01',
    title: 'Select text anywhere',
    body: 'Fluent App uses macOS Accessibility permissions to capture the current text selection from the active app.'
  },
  {
    index: '02',
    title: 'Press your shortcut',
    body: 'Use the default actions or define your own global shortcuts with custom prompts and providers.'
  },
  {
    index: '03',
    title: 'Replace it instantly',
    body: 'The selected text is sent to your chosen model and pasted back in place without leaving your current context.'
  }
];

const openSourceCards = [
  {
    title: 'Open repository',
    body: 'The complete app, release scripts, and website are public on GitHub and easy to inspect or fork.',
    href: repoUrl,
    label: 'View repository'
  },
  {
    title: 'Automated releases',
    body: 'GitHub Actions build the app, generate release artifacts, and support signing plus notarization for public distribution.',
    href: `${repoUrl}/actions`,
    label: 'View workflows'
  },
  {
    title: 'MIT licensed',
    body: 'Use Fluent App as-is, adapt it for your own team, or ship your own variant without hidden platform lock-in.',
    href: `${repoUrl}/blob/main/LICENSE`,
    label: 'Read license'
  }
];

const defaultShortcuts = [
  {
    keys: ['Cmd', 'Shift', 'O'],
    title: 'Translate',
    body: 'Detect the language and translate the selection cleanly.'
  },
  {
    keys: ['Cmd', 'Shift', 'I'],
    title: 'Improve Writing',
    body: 'Rewrite for clarity, grammar, and tone while keeping the same language.'
  },
  {
    keys: ['Cmd', 'Shift', 'S'],
    title: 'Summarize',
    body: 'Condense selected text into concise output using your own prompt style.'
  }
];
---

<Layout title={title} description={description}>
  <main class="mx-auto max-w-[1240px] px-4 pb-16 pt-5 sm:px-6 sm:pb-24">
    <section class="surface-card bg-hero-glow p-6 shadow-halo sm:p-8">
      <header class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <a href="/" class="inline-flex items-center gap-3 no-underline">
          <span class="inline-flex h-11 w-11 items-center justify-center overflow-hidden rounded-2xl border border-white/10 bg-white/5">
            <img src="/favicon.svg" alt="" class="h-full w-full object-cover" />
          </span>
          <span class="text-base font-semibold tracking-[-0.03em] text-white">Fluent App</span>
        </a>

        <nav class="flex flex-wrap items-center gap-5 text-sm text-white/65" aria-label="Primary">
          <a href="#features" class="transition hover:text-white">Features</a>
          <a href="#how-it-works" class="transition hover:text-white">How it works</a>
          <a href="#open-source" class="transition hover:text-white">Open source</a>
          <a href={repoUrl} class="transition hover:text-white" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </header>

      <div class="grid gap-12 lg:grid-cols-[minmax(0,1.12fr)_minmax(380px,0.88fr)] lg:items-center">
        <div>
          <span class="eyebrow">
            <span class="h-2 w-2 rounded-full bg-white/90"></span>
            Native macOS menu bar app
          </span>

          <h1 class="mt-5 max-w-[11ch] text-5xl font-semibold leading-[0.93] tracking-tighterest text-white sm:text-7xl xl:text-[5.7rem]">
            AI shortcuts for the text you already have selected.
          </h1>

          <p class="mt-6 max-w-2xl text-base leading-7 text-white/68 sm:text-lg">
            Fluent App lives in the menu bar, listens for your global shortcuts, captures selected text from any app,
            sends it to your preferred model, and pastes the result back in place. No manual copy and paste. No context switching.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              class="pill-button border-white bg-white text-black"
              id="download-latest"
              href={releasesUrl}
              data-release-api="https://api.github.com/repos/alfonsobries/fluent-app/releases/latest"
              data-release-fallback={releasesUrl}
            >
              Download for macOS
            </a>
            <a class="pill-button border-white/10 bg-white/5 text-white" href={repoUrl} target="_blank" rel="noreferrer">
              View on GitHub
            </a>
          </div>

          <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-sm text-white/45">
            <span>MIT licensed</span>
            <span>Open source</span>
            <span>macOS 13+</span>
            <span>OpenAI, Claude, Gemini, Grok</span>
          </div>
        </div>

        <div class="relative">
          <div class="overflow-hidden rounded-[28px] border border-white/10 bg-white/[0.03] shadow-[inset_0_1px_0_rgba(255,255,255,0.08)]">
            <div class="flex h-14 items-center gap-2 border-b border-white/5 px-5">
              <span class="h-3 w-3 rounded-full bg-white/15"></span>
              <span class="h-3 w-3 rounded-full bg-white/15"></span>
              <span class="h-3 w-3 rounded-full bg-white/15"></span>
            </div>

            <div class="space-y-5 p-5">
              <div class="flex items-center justify-between gap-4">
                <div class="inline-flex h-8 w-8 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-white/5">
                  <img src="/favicon.svg" alt="" class="h-full w-full object-cover" />
                </div>
                <div class="rounded-full border border-white/10 bg-black/70 px-3 py-2 text-xs font-medium text-white/90">
                  Translating...
                </div>
              </div>

              <div class="rounded-[24px] border border-white/10 bg-white/[0.035] p-5">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-sm font-semibold text-white">Fluent App</p>
                    <p class="mt-1 text-sm text-white/50">Shortcuts</p>
                  </div>
                  <div class="rounded-full bg-white/6 px-3 py-1.5 text-xs text-white/80">OpenAI</div>
                </div>

                <div class="mt-5 space-y-3">
                  <div class="flex items-center justify-between gap-4 rounded-2xl bg-white/[0.03] px-4 py-3">
                    <div>
                      <p class="text-sm font-semibold text-white">Translate</p>
                      <p class="text-sm text-white/50">Cmd + Shift + O</p>
                    </div>
                    <span class="rounded-full bg-white/6 px-3 py-1 text-xs text-white/80">On</span>
                  </div>
                  <div class="flex items-center justify-between gap-4 rounded-2xl bg-white/[0.03] px-4 py-3">
                    <div>
                      <p class="text-sm font-semibold text-white">Improve Writing</p>
                      <p class="text-sm text-white/50">Cmd + Shift + I</p>
                    </div>
                    <span class="rounded-full bg-white/6 px-3 py-1 text-xs text-white/80">On</span>
                  </div>
                  <div class="flex items-center justify-between gap-4 rounded-2xl bg-white/[0.03] px-4 py-3 opacity-80">
                    <div>
                      <p class="text-sm font-semibold text-white">Summarize</p>
                      <p class="text-sm text-white/50">Custom prompt</p>
                    </div>
                    <span class="rounded-full bg-white/6 px-3 py-1 text-xs text-white/80">New</span>
                  </div>
                </div>

                <div class="mt-4 rounded-2xl bg-black/20 p-4">
                  <p class="text-xs uppercase tracking-[0.12em] text-white/45">Prompt</p>
                  <p class="mt-2 text-sm leading-6 text-white/78">
                    Summarize the selected text in 3 concise bullet points. Keep the same language as the input.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-5 grid gap-4 lg:grid-cols-3">
      <article class="surface-card p-6">
        <h2 class="text-lg font-semibold tracking-[-0.03em] text-white">Global shortcuts</h2>
        <p class="mt-2 text-sm leading-6 text-white/65">Trigger actions from any app and keep your hands on the keyboard.</p>
      </article>
      <article class="surface-card p-6">
        <h2 class="text-lg font-semibold tracking-[-0.03em] text-white">Bring your own model</h2>
        <p class="mt-2 text-sm leading-6 text-white/65">Use OpenAI, Claude, Gemini, or Grok without changing the app around your workflow.</p>
      </article>
      <article class="surface-card p-6">
        <h2 class="text-lg font-semibold tracking-[-0.03em] text-white">Open-source release flow</h2>
        <p class="mt-2 text-sm leading-6 text-white/65">GitHub releases, checksums, CI, and Apple signing support are already part of the project.</p>
      </article>
    </section>

    <section id="features" class="mt-24">
      <div class="max-w-3xl">
        <span class="eyebrow">Features</span>
        <h2 class="section-title">Built for people who rewrite text all day.</h2>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {featureCards.map((feature) => (
          <article class="surface-card p-6">
            <h3 class="text-lg font-semibold tracking-[-0.03em] text-white">{feature.title}</h3>
            <p class="mt-3 text-sm leading-6 text-white/65">{feature.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="how-it-works" class="mt-24">
      <div class="max-w-3xl">
        <span class="eyebrow">How it works</span>
        <h2 class="section-title">Three steps. No context switching.</h2>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {steps.map((step) => (
          <article class="surface-card p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-white/40">{step.index}</p>
            <h3 class="mt-6 text-lg font-semibold tracking-[-0.03em] text-white">{step.title}</h3>
            <p class="mt-3 text-sm leading-6 text-white/65">{step.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-24">
      <div class="max-w-3xl">
        <span class="eyebrow">Defaults</span>
        <h2 class="section-title">Start useful, then make it your own.</h2>
      </div>

      <div class="surface-card mt-8 overflow-hidden">
        {defaultShortcuts.map((shortcut) => (
          <div class="grid gap-4 border-b border-white/5 px-6 py-6 last:border-b-0 md:grid-cols-[240px_1fr] md:items-center">
            <div class="flex flex-wrap items-center gap-2">
              {shortcut.keys.map((key) => (
                <kbd class="rounded-lg border border-white/10 bg-white/8 px-2.5 py-1 font-mono text-xs text-white">
                  {key}
                </kbd>
              ))}
            </div>
            <div>
              <p class="text-base font-semibold tracking-[-0.03em] text-white">{shortcut.title}</p>
              <p class="mt-2 text-sm leading-6 text-white/65">{shortcut.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-24">
      <div class="surface-card grid gap-8 p-7 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <div class="max-w-3xl">
          <span class="eyebrow">Download</span>
          <h2 class="section-title">Install the latest release.</h2>
          <p class="mt-4 text-base leading-7 text-white/65">
            The download button resolves the latest GitHub release asset directly. If you later publish separate
            Apple Silicon and Intel DMGs, the same logic can choose the best file automatically based on the visitor platform.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            class="pill-button border-white bg-white text-black"
            id="download-release-card"
            href={releasesUrl}
            data-release-api="https://api.github.com/repos/alfonsobries/fluent-app/releases/latest"
            data-release-fallback={releasesUrl}
          >
            Download Latest DMG
          </a>
          <a class="pill-button border-white/10 bg-white/5 text-white" href={`${repoUrl}/releases`} target="_blank" rel="noreferrer">
            All Releases
          </a>
        </div>
      </div>
    </section>

    <section id="open-source" class="mt-24">
      <div class="max-w-3xl">
        <span class="eyebrow">Open source</span>
        <h2 class="section-title">Public, inspectable, and ready to ship.</h2>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {openSourceCards.map((card) => (
          <article class="surface-card p-6">
            <h3 class="text-lg font-semibold tracking-[-0.03em] text-white">{card.title}</h3>
            <p class="mt-3 text-sm leading-6 text-white/65">{card.body}</p>
            <a class="mt-5 inline-flex text-sm text-white/70 transition hover:text-white" href={card.href} target="_blank" rel="noreferrer">
              {card.label}
            </a>
          </article>
        ))}
      </div>
    </section>

    <footer class="mt-24 flex flex-col gap-6 pt-6 text-sm text-white/55 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-lg">
        <p class="text-base font-semibold tracking-[-0.03em] text-white">Fluent App</p>
        <p class="mt-2 leading-6 text-white/55">
          Open-source macOS AI shortcuts for translation, rewriting, summaries, and custom text automation.
        </p>
      </div>

      <nav class="flex flex-wrap gap-4" aria-label="Footer">
        <a class="transition hover:text-white" href={repoUrl}>GitHub</a>
        <a class="transition hover:text-white" href={`${repoUrl}/releases`}>Releases</a>
        <a class="transition hover:text-white" href={`${repoUrl}/issues`}>Issues</a>
        <a class="transition hover:text-white" href={`${repoUrl}/blob/main/README.md`}>Docs</a>
      </nav>
    </footer>
  </main>

  <script is:inline>
    const buttons = Array.from(document.querySelectorAll('[data-release-api]'));
    const preferredArch = (() => {
      const platform = navigator.userAgentData?.platform || navigator.platform || '';
      const ua = navigator.userAgent || '';
      if (/arm|apple/i.test(platform) || /arm|apple/i.test(ua)) return 'apple-silicon';
      if (/intel|x86_64|macintel/i.test(platform) || /intel|x86_64|macintosh/i.test(ua)) return 'intel';
      return 'generic';
    })();

    const pickAsset = (assets) => {
      const dmgAssets = assets.filter((asset) => asset.name?.endsWith('.dmg'));
      if (!dmgAssets.length) return null;

      const archHintMap = {
        'apple-silicon': ['apple-silicon', 'arm64', 'aarch64'],
        intel: ['intel', 'x64', 'x86_64']
      };

      const hints = archHintMap[preferredArch] || [];
      const exactMatch = dmgAssets.find((asset) =>
        hints.some((hint) => asset.name.toLowerCase().includes(hint))
      );

      return exactMatch || dmgAssets[0];
    };

    const hydrateDownloadButtons = async () => {
      if (!buttons.length) return;

      try {
        const response = await fetch(buttons[0].dataset.releaseApi, {
          headers: { Accept: 'application/vnd.github+json' }
        });
        if (!response.ok) throw new Error('Failed to fetch latest release');

        const release = await response.json();
        const asset = pickAsset(release.assets || []);

        if (!asset?.browser_download_url) return;

        buttons.forEach((button) => {
          button.href = asset.browser_download_url;
          button.textContent =
            preferredArch === 'generic'
              ? 'Download Latest DMG'
              : `Download for ${preferredArch === 'apple-silicon' ? 'Apple Silicon' : 'Intel'}`;
        });
      } catch {
        buttons.forEach((button) => {
          button.href = button.dataset.releaseFallback || button.href;
        });
      }
    };

    hydrateDownloadButtons();
  </script>
</Layout>
